# Argus Demo — The All-Seeing Eye
# Record with: vhs demo.tape

Output demo.gif
Set Shell bash
Set Width 1400
Set Height 750
Set FontSize 13
Set Padding 10
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms
Set CursorBlink false

# --- Launch Argus watching itself ---
Type "./run.sh ."
Enter

# Let it settle and record real activity
Sleep 45s

# Quit
Type "q"
Sleep 1s
